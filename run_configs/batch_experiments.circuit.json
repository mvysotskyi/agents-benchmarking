{
  "max_parallel": 15,
  "fail_fast": false,
  "termination_grace_period": 2,
  "defaults": {
    "run_all": true,
    "headless": true,
    "max_steps": 60,
    "task_file": "test_cases/circuit.yaml",
    "post_run_url": "",
    "prefix_prompt_file": "app_background/circuit.md",
    "post_run_js_snippet_path": "assets/circuit_txt_export_snippet.js",
    "url": "https://circuitjs1-production.up.railway.app/circuitjs.html?startCircuit=blank.txt",
    "seed": 42
  },
  "models": {
    "gpt-5.4": {
      "testcases": [
        {
          "name": "gpt54-circuit",
          "results_dir": "final_results/circuit/gpt54",
          "reasoning": true,
          "task_range": "2:"
        },
        {
          "skip_existing_results": true,
          "name": "gpt54-circuit-no-reasoning",
          "results_dir": "final_results/circuit/gpt54_no_reasoning",
          "reasoning": false
        }
      ]
    },
    "o3-pro": {
